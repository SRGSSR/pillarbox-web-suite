{
  "name": "@srgssr/drm-support",
  "version": "0.0.1",
  "license": "MIT",
  "author": "SRG SSR",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SRGSSR/pillarbox-web-suite.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/SRGSSR/pillarbox-web-suite/tree/main/packages/drm-support#readme",
  "type": "module",
  "main": "dist/drm-support.cjs",
  "browser": "dist/drm-support.umd.min.js",
  "module": "dist/drm-support.js",
  "exports": {
    ".": {
      "import": "./dist/drm-support.js",
      "require": "./dist/drm-support.cjs"
    },
    "./*": "./*"
  },
  "files": [
    "dist/*"
  ],
  "keywords": [
    "video.js",
    "player",
    "videojs-plugin"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm-run-all clean build:*",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:umd": "vite build --config vite.config.umd.js",
    "github:page": "vite build",
    "release:ci": "semantic-release",
    "start": " vite --port 4200 --open --host",
    "test": "vitest run --silent --coverage --coverage.reporter text"
  },
  "peerDependencies": {
    "video.js": "^8.0.0"
  },
  "devDependencies": {
    "@srgssr/pillarbox-web": "^1.24.1"
  }
}
