{
  "name": "@srgssr/srg-ssr-hotkeys",
  "description": "Keyboard shortcuts to control the player as defined by the SRG SSR.",
  "version": "1.0.0",
  "license": "MIT",
  "author": "SRG SSR",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SRGSSR/pillarbox-web-suite.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/SRGSSR/pillarbox-web-suite/tree/main/packages/srg-ssr-hotkeys#readme",
  "type": "module",
  "main": "dist/srg-ssr-hotkeys.cjs",
  "browser": "dist/srg-ssr-hotkeys.umd.min.js",
  "module": "dist/srg-ssr-hotkeys.js",
  "exports": {
    ".": {
      "import": "./dist/srg-ssr-hotkeys.js",
      "require": "./dist/srg-ssr-hotkeys.cjs"
    },
    "./*": "./*"
  },
  "files": [
    "dist/*"
  ],
  "keywords": [
    "video.js",
    "player",
    "pillarbox"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm-run-all clean build:*",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:umd": "vite build --config vite.config.umd.js",
    "github:page": "vite build",
    "release:ci": "semantic-release",
    "start": " vite --port 4200 --open",
    "test": "vitest run --silent --coverage --coverage.reporter text"
  }
}
